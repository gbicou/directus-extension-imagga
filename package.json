{
  "name": "@bicou/directus-extension-imagga",
  "description": "Automatic image tagging of Directus files with Imagga API",
  "homepage": "https://github.com/gbicou/directus-extension-imagga",
  "author": "Benjamin VIELLARD <bicou@bicou.com>",
  "license": "MIT",
  "repository": "github:gbicou/directus-extension-imagga",
  "icon": "extension",
  "version": "1.6.6",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-hook",
    "image",
    "tag",
    "auto-tagging",
    "imagga"
  ],
  "directus:extension": {
    "type": "hook",
    "path": "dist/index.mjs",
    "source": "src/index.ts",
    "host": "^11.1.0"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@directus/api": "^33.0.0",
    "@directus/extensions-sdk": "^17.0.0",
    "axios": "^1.9.0",
    "form-data": "^4.0.2"
  },
  "devDependencies": {
    "@directus/sdk": "21.2.0",
    "@directus/tsconfig": "3.0.0",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "22.19.15",
    "dotenv": "17.3.1",
    "eslint": "10.0.3",
    "eslint-plugin-unicorn": "63.0.0",
    "rollup-plugin-node-externals": "8.1.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.0",
    "wiremock-captain": "4.1.3"
  },
  "peerDependencies": {
    "@directus/api": "^33.0.0",
    "@directus/env": "^5.0.2",
    "@directus/extensions-sdk": "^17.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
